# BeQuite — repository .gitignore
# Receipts, memory, and prompts ARE tracked. Secrets, build outputs, and per-developer state are not.

# --- Secrets (Article V — never committed) ---
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
.bequite/.keys/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# --- Node / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
.yarn/
.next/
.turbo/
.parcel-cache/
.cache/

# --- Rust / Tauri ---
target/
Cargo.lock.bak
src-tauri/target/

# --- IDE / OS ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- Coverage & test outputs ---
coverage/
.nyc_output/
playwright-report/
test-results/
e2e-results/

# --- BeQuite per-developer state ---
.bequite/auto-state/*.json
.bequite/replays/
.bequite/cache/

# --- BeQuite tracked artifacts (DO NOT IGNORE) ---
# Receipts, memory, prompts, logs, decisions, specs, AGENTS.md, CLAUDE.md, doctrines
# are all tracked. Listed here for clarity:
# !.bequite/memory/
# !.bequite/receipts/
# !.bequite/memory/prompts/

# --- Local-only configs (override-able) ---
.claude/settings.local.json
*.local.toml

# --- Generated docs ---
docs/_build/
site/
