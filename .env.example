# BeQuite — environment variable reference (.env.example)
#
# Copy this file to .env at the repo root if you want to override defaults.
# All values shown here ARE the defaults — uncommenting them is optional.
#
# Local-dev mode works WITHOUT any env vars. You only need to set these when:
#   - You're exposing BeQuite beyond localhost (set AUTH_MODE=token)
#   - You're swapping API base URLs (multi-host dev)
#   - You're widening the workspace root for cross-project work

# ============================================================================
# API (studio/api/) — Hono on Bun, port 3002
# ============================================================================

# Auth mode for the Studio API.
#   local-dev   (default)  Pass-through. Single-machine dev. No token required.
#   token                  Bearer auth. Tokens at <workspace>/.bequite/.auth/tokens.json.
#   device-code            RFC 8628. Auth server lands v2.0.0-alpha.3+.
#
# BEQUITE_AUTH_MODE=local-dev

# Workspace root the API is allowed to read. Defaults to two-levels-up from
# the API's cwd. In Docker, this is overridden to /workspace (the volume mount).
# Set ONLY if you want the API to scope to a specific project subdir.
#
# BEQUITE_WORKSPACE_ROOT=/abs/path/to/your/workspace

# API port (Docker forwards this to host).
#
# PORT=3002

# ============================================================================
# Dashboard (studio/dashboard/) — Next.js 15, port 3001
# ============================================================================

# Dashboard loader mode.
#   filesystem (default)   Server components read .bequite/ directly from disk.
#                          Single-machine dev only.
#   http                   Server components fetch from studio/api/.
#                          Required for the live LiveIndicator + xterm Terminal.
#
# BEQUITE_DASHBOARD_MODE=filesystem

# Server-side API base URL (used by Next.js server components when in http mode).
# In Docker compose, defaults to http://api:3002 (service-name resolution).
# Locally without Docker, set this to http://localhost:3002.
#
# BEQUITE_API_BASE=http://localhost:3002

# Build-time API base (baked into the client JS bundle for browser EventSource).
# This is the URL the BROWSER uses for SSE — must be reachable from outside Docker.
# When the dashboard runs in Docker, set this at build time:
#   --build-arg NEXT_PUBLIC_BEQUITE_API_BASE=http://localhost:3002
#
# NEXT_PUBLIC_BEQUITE_API_BASE=http://localhost:3002

# Optional: Bearer token for token-mode APIs. Omit in local-dev.
# Set this in .env.local for the dashboard to authenticate to a token-mode API.
#
# NEXT_PUBLIC_BEQUITE_API_TOKEN=

# ============================================================================
# Marketing (studio/marketing/) — Next.js 15, port 3000
# ============================================================================
# No env vars required. Static site.

# ============================================================================
# CLI (cli/) — Python 3.11+
# ============================================================================

# Cost ceiling for `bequite auto` (USD per session). Default: 20.00
#
# BEQUITE_MAX_COST_USD=20.00

# Wall-clock ceiling for `bequite auto` (hours). Default: 6
#
# BEQUITE_MAX_WALL_CLOCK_HOURS=6

# Offline mode — disables network calls (freshness probe, pricing fetch).
# Use in air-gapped environments.
#
# BEQUITE_OFFLINE=false

# CI mode — disables interactive prompts, uses BEQUITE_API_KEY directly.
#
# BEQUITE_CI_MODE=false
# BEQUITE_API_KEY=

# ============================================================================
# Anthropic API (for the CLI's multi-model + receipts)
# ============================================================================
# Required ONLY if you're running `bequite auto` or `bequite multi-model` with
# Anthropic as the primary provider. Free-tier Claude usage works with this key.
#
# ANTHROPIC_API_KEY=
