{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "BeQuite Studio brand tokens (v0.16.0). Source of truth for both Tailwind config + CSS-in-JS consumers.",
  "color": {
    "gold": {
      "50":   { "$value": "#FBF3E0", "$type": "color" },
      "100":  { "$value": "#F7E5B5", "$type": "color" },
      "200":  { "$value": "#F2D27D", "$type": "color" },
      "300":  { "$value": "#ECC050", "$type": "color" },
      "bright":  { "$value": "#F2C76A", "$type": "color" },
      "primary": { "$value": "#E5B547", "$type": "color" },
      "deep":    { "$value": "#B8861E", "$type": "color" },
      "shadow":  { "$value": "#6B4F11", "$type": "color" }
    },
    "black": {
      "pure":   { "$value": "#000000", "$type": "color" },
      "stage":  { "$value": "#0A0A0A", "$type": "color" },
      "velvet": { "$value": "#141414", "$type": "color" },
      "edge":   { "$value": "#1F1F1F", "$type": "color" }
    },
    "neutral": {
      "silver":     { "$value": "#D4D4D4", "$type": "color" },
      "silver-soft":{ "$value": "#A3A3A3", "$type": "color" },
      "silver-dim": { "$value": "#6B6B6B", "$type": "color" },
      "white":      { "$value": "#FFFFFF", "$type": "color" }
    },
    "state": {
      "success": { "$value": "#22C55E", "$type": "color" },
      "warning": { "$value": "#F59E0B", "$type": "color" },
      "danger":  { "$value": "#EF4444", "$type": "color" }
    }
  },
  "font": {
    "display": { "$value": "Geist, 'Inter Display', Inter, system-ui, sans-serif", "$type": "fontFamily" },
    "sans":    { "$value": "Geist, Inter, system-ui, sans-serif",                  "$type": "fontFamily" },
    "mono":    { "$value": "'Geist Mono', 'JetBrains Mono', 'Fira Code', monospace", "$type": "fontFamily" }
  },
  "motion": {
    "ease": {
      "cinematic": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
      "soft-in":   { "$value": "cubic-bezier(0.4, 0, 0.6, 1)",  "$type": "cubicBezier" },
      "in-out":    { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",  "$type": "cubicBezier" }
    },
    "duration": {
      "instant":   { "$value": "75ms",   "$type": "duration" },
      "quick":     { "$value": "200ms",  "$type": "duration" },
      "base":      { "$value": "400ms",  "$type": "duration" },
      "slow":      { "$value": "600ms",  "$type": "duration" },
      "cinematic": { "$value": "900ms",  "$type": "duration" },
      "stage":     { "$value": "1600ms", "$type": "duration" }
    }
  }
}
