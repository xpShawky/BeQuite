{
  "name": "@bequite/api",
  "version": "0.19.0",
  "private": true,
  "description": "BeQuite Studio API — Hono on Bun back-end serving the dashboard. Reads .bequite/, state/, receipts. Per ADR-013.",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.23.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.6.3"
  }
}
