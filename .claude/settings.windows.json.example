{
  "_comment_bequite": "OPT-IN BeQuite hooks (Windows, PowerShell). Review the .ps1 scripts first, then MERGE this 'hooks' block into your real .claude/settings.json (or settings.local.json). Do NOT blindly overwrite an existing settings file. You may also need: Set-ExecutionPolicy -Scope CurrentUser RemoteSigned. See docs/architecture/CLAUDE_CODE_HOOKS_STRATEGY.md.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          { "type": "command", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR\\.claude\\hooks\\pretooluse-block-destructive.ps1\"", "timeout": 15 }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR\\.claude\\hooks\\pretooluse-secret-scan.ps1\"", "timeout": 15 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$CLAUDE_PROJECT_DIR\\.claude\\hooks\\stop-banned-weasel-words.ps1\"", "timeout": 15 }
        ]
      }
    ]
  }
}
